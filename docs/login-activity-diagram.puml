@startuml
start
:Użytkownik wpisuje e-mail i hasło;
:System pobiera IP i User-Agent;
if (Czy IP jest dozwolone?) then (tak albo lista pusta)
  :Wyszukanie konta po e-mailu;
  if (Konto istnieje?) then (tak)
    :ASP.NET Identity weryfikuje hasło;
    if (Hasło poprawne?) then (tak)
      :Wyzerowanie licznika błędów;
      :Zapis LoginAuditLog z Success=true;
      :Zapis UserActivity LOGIN;
      if (Hasło starsze niż 90 dni?) then (tak)
        :Przekierowanie do zmiany hasła;
      else (nie)
        if (Użytkownik chce widzieć tabelę czynności?) then (tak)
          :Wyświetlenie tabeli czynności;
        else (nie)
          :Przejście do strony głównej;
        endif
      endif
    else (nie)
      :Zwiększenie AccessFailedCount;
      :Zapis LoginAuditLog z Success=false;
      if (Przekroczono próg prób?) then (tak)
        :Ustawienie LockoutEnd;
        :Komunikat o blokadzie konta;
      else (nie)
        :Komunikat o błędnym loginie lub haśle;
      endif
    endif
  else (nie)
    :Zapis nieudanej próby bez UserId;
    :Komunikat o błędnym loginie lub haśle;
  endif
else (nie)
  :HTTP 403 - IP zablokowane;
endif
stop
@enduml
