@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Przypomnienie hasła";
}
<h1>Przypomnienie hasła</h1>
<form asp-action="ForgotPassword" method="post" class="form-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>
    <label asp-for="Email"></label>
    <input asp-for="Email" />
    <span asp-validation-for="Email" class="validation"></span>
    <button type="submit">Wyślij link resetujący</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
