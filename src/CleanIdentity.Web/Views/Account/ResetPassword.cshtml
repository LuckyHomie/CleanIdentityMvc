@model ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset hasła";
}
<h1>Reset hasła</h1>
<form asp-action="ResetPassword" method="post" class="form-card">
    <input asp-for="Email" type="hidden" />
    <input asp-for="Token" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="validation"></div>

    <label asp-for="NewPassword"></label>
    <input asp-for="NewPassword" />
    <span asp-validation-for="NewPassword" class="validation"></span>

    <label asp-for="ConfirmPassword"></label>
    <input asp-for="ConfirmPassword" />
    <span asp-validation-for="ConfirmPassword" class="validation"></span>

    <button type="submit">Ustaw nowe hasło</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
