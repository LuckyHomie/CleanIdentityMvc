@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Zmiana hasła";
}
<h1>Zmiana hasła</h1>
@if (Model.Expired)
{
    <div class="alert">Hasło przekroczyło maksymalny okres ważności. Zmień je, aby kontynuować.</div>
}
<form asp-action="ChangePassword" method="post" class="form-card">
    <div asp-validation-summary="ModelOnly" class="validation"></div>

    <label asp-for="CurrentPassword"></label>
    <input asp-for="CurrentPassword" />
    <span asp-validation-for="CurrentPassword" class="validation"></span>

    <label asp-for="NewPassword"></label>
    <input asp-for="NewPassword" />
    <span asp-validation-for="NewPassword" class="validation"></span>

    <label asp-for="ConfirmPassword"></label>
    <input asp-for="ConfirmPassword" />
    <span asp-validation-for="ConfirmPassword" class="validation"></span>

    <button type="submit">Zmień hasło</button>
</form>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
